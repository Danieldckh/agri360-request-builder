# Agri360 CRM base URL (no trailing slash). The server proxies /api/* here.
CRM_API_BASE=https://agri360.proagrihub.com

# Shared builder key injected as the X-Builder-Key header SERVER-SIDE.
# Never exposed to the browser. Paste the real value in Coolify env, not here.
BUILDER_KEY=PASTE_BUILDER_KEY_HERE

# Public client-portal base (no trailing slash). After publish, the SPA opens
# CLIENT_PORTAL_BASE + '/form/' + token in a new tab.
CLIENT_PORTAL_BASE=https://clientportal.proagrihub.com

# Port the server listens on (Coolify sets this; defaults to 3000).
PORT=3000
